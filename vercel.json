{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    {
      "has": [{ "type": "host", "value": "api.sitegist.co" }],
      "source": "/v1/:path*",
      "destination": "/api/v1/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/usage-warnings",
      "schedule": "0 9 * * *"
    }
  ]
}
