# --- Database (REQUIRED) ---
# Prisma connection string (PostgreSQL/Supabase/etc.)
DATABASE_URL= 
# Used for session cookies
SESSION_SECRET="super-secret-session-key"

# --- AI & LlamaStack (REQUIRED) ---
# Gemini API Key
GEMINI_API_KEY= 
VITE_GEMINI_API_KEY= 


# --- Vector Database (REQUIRED for RAG) ---
# Pinecone for storing and querying website embeddings
PINECONE_API_KEY=
PINECONE_INDEX=quickstart
# Pin ONE embedding provider and model for the whole app ("openai" | "gemini")
# Defaulting to "openai" (text-embedding-3-small, 1536 dim). Use "gemini" (text-embedding-004, 768 dim) otherwise.
# IMPORTANT: The Pinecone Index MUST be created with the matching dimension!
EMBEDDING_PROVIDER=openai

# --- AI Gateway & Observability (RECOMMENDED) ---
# Open AI Key (if using GPT models)
OPENAI_API_KEY= 

VITE_OPENAI_API_KEY= 

# Portkey Virtual Key (for model routing/caching)
PORTKEY_API_KEY=
PORTKEY_VIRTUAL_KEY=
PORTKEY_COHERE_VIRTUAL_KEY=
PORTKEY_MODEL=
PORTKEY_MAX_TOKENS=2048

# --- Web Scraping (REQUIRED for AI Training) ---
# Firecrawl for deep crawling of websites
FIRECRAWL_API_KEY=

# --- Storage (FOR FILE UPLOADS) ---
# Cloudflare R2 or AWS S3
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN="https://pub-...r2.dev"

# --- Analytics & Tracking ---
# PostHog for user behavior analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# --- Security (OPTIONAL) ---
# Cloudflare Turnstile (CAPTCHA)
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# --- Payments (FOR BILLING) ---
# Stripe or Paddle

PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT="production" # or "sandbox"

VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_STARTER_PLAN_ID=
VITE_PADDLE_BASIC_PLAN_ID=
VITE_PADDLE_PRO_PLAN_ID=

# Reusable Checkout Config Price IDs
VITE_PADDLE_STARTER_MONTHLY_PRICE_ID=
VITE_PADDLE_PRO_MONTHLY_PRICE_ID=
VITE_PADDLE_ENTERPRISE_MONTHLY_PRICE_ID=
VITE_PADDLE_STARTER_YEARLY_PRICE_ID=
VITE_PADDLE_PRO_YEARLY_PRICE_ID=
VITE_PADDLE_ENTERPRISE_YEARLY_PRICE_ID=

# --- Real-time & Caching (OPTIONAL) ---
# Upstash Redis for magic links fallback and caching
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Upstash Workflow for background jobs
UPSTASH_WORKFLOW_URL=

PARTYKIT_HOST=

# --- Crisp Integration ---
CRISP_CLIENT_ID=
CRISP_CLIENT_SECRET=
CRISP_PLUGIN_ID=
CRISP_PLUGIN_KEY=

# --- Intercom Integration ---
INTERCOM_CLIENT_ID=
INTERCOM_CLIENT_SECRET=

# --- YouTube Integration ---
YOUTUBE_API_KEY=

# --- Cron Scheduler (For Weekly Digest) ---
CRON_SECRET=

# --- Webhook Signing Secret (OPTIONAL) ---
WEBHOOK_SECRET="your-random-secret-here"

# --- Zoho Desk Integration (OAuth) ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ACCOUNTS_URL="https://accounts.zoho.com"
ZOHO_DESK_URL="https://desk.zoho.com"

