generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                @id @default(cuid())
  email            String                @unique
  passwordHash     String?               // Make optional as we'll use magic links
  role             String                @default("USER") // OWNER, ADMIN, USER
  subscriptionTier String                @default("free")
  subscriptionStatus String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  projects         Project[]
  subscriptions    BillingSubscription[]
  sessions         ChatSession[]
  usageRecords     UsageRecord[]
  blogPosts        BlogPost[]
  apiKeys          ApiKey[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model BlogPost {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String   @db.Text
  content         String   @db.Text
  coverImage      String?
  metaTitle       String?
  seoTitle        String?
  metaDescription String?  @db.Text
  seoDescription  String?  @db.Text
  tags            String?  // Store as comma-separated string or Json
  published       Boolean  @default(false)
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Project {
  id               String            @id @default(cuid())
  name             String
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  status           ProjectStatus     @default(ACTIVE)
  settings         Json?             // systemPrompt, branding, colors, theme, customDomain, removeBranding
  webhookUrl       String?           // For Slack/Discord or custom alerts
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  knowledgeSources KnowledgeSource[]
  leads            Lead[]
  sessions         ChatSession[]
  unansweredQuestions UnansweredQuestion[]
  analyticsSnapshots  AnalyticsSnapshot[]
  integrations         Integration[]
  knowledgeQAs         KnowledgeQA[]
  members              ProjectMember[]
}

model Integration {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  provider     String   // 'notion', 'google_drive'
  accessToken  String
  refreshToken String?
  details      Json?    // e.g., workspace name, user email
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, provider])
}

model KnowledgeSource {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  type          String   // 'web', 'file', 'youtube', 'text'
  source        String   // URL or Filename
  title         String?
  content       String?  @db.Text
  metadata      Json?    // e.g., file size, specific youtube ID metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  search_vector Unsupported("tsvector")? // Managed via raw SQL migration as it is stored and generated

  @@index([projectId])
}

model ChatSession {
  id          String    @id @default(cuid())
  projectId   String    
  project     Project   @relation(fields: [projectId], references: [id])
  userId      String?   
  user        User?     @relation(fields: [userId], references: [id])
  customerEmail String? // For guest identification
  status      String    @default("active") // active, resolved
  mode        String    @default("ai") // ai, human
  isRead      Boolean   @default(false)
  isStarred   Boolean   @default(false)
  isArchived  Boolean   @default(false)
  assignedTo  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
  tags        ConversationTag[]
  lead        Lead?
}

model Message {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  role      String      // 'user' or 'assistant'
  content   String      @db.Text
  feedback  Int?        // 1 for thumbs up, -1 for thumbs down
  createdAt DateTime    @default(now())
}

model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // 'chat_message', 'crawled_page', 'file_upload'
  amount    Int      @default(1)
  createdAt DateTime @default(now())
}

model BillingSubscription {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  externalSubscriptionId String   @unique // Renamed from stripeSubscriptionId
  externalCustomerId     String           // Renamed from stripeCustomerId
  status               String
  planId               String
  provider             String   @default("stripe") // "stripe" or "paddle"
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  nextBilledAt         DateTime?
}

model Lead {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id])
  name      String?
  email     String?
  phone     String?
  company   String?
  status    String    @default("new")
  isStarred Boolean   @default(false)
  isArchived Boolean  @default(false)
  notes     String?   @db.Text
  sessionId String?   @unique
  session   ChatSession? @relation(fields: [sessionId], references: [id])
  tags      LeadTag[]
  createdAt DateTime  @default(now())
}

model UnansweredQuestion {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  question  String   @db.Text
  createdAt DateTime @default(now())
}

model AnalyticsSnapshot {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  date            DateTime @default(now())
  messagesCount   Int      @default(0)
  leadsCaptured   Int      @default(0)
  avgLatency      Float?
  unansweredCount Int      @default(0)
}

model KnowledgeQA {
  id           String   @id @default(cuid())
  projectId    String
  question     String   @db.Text
  answer       String   @db.Text
  triggerCount Int      @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum ProjectStatus {
  ACTIVE
  TRAINING
  ERROR
}

enum MemberRole {
  VIEWER
  ADMIN
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email     String
  role      MemberRole @default(VIEWER)
  createdAt DateTime @default(now())
  @@unique([projectId, email])
}

model ConversationTag {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  label     String
  color     String      @default("#6366f1")
  createdAt DateTime    @default(now())
  @@unique([sessionId, label])
}

model LeadTag {
  id      String   @id @default(cuid())
  leadId  String
  lead    Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  label   String
  color   String   @default("#6366f1")
  createdAt DateTime @default(now())
  @@unique([leadId, label])
}

model BillingPayment {
  id            String   @id @default(cuid())
  userId        String
  transactionId String   @unique
  amount        Float
  currency      String
  status        String
  invoiceUrl    String?
  paidAt        DateTime
  createdAt     DateTime @default(now())
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique   // sha256 hash of the full key
  prefix     String              // first 12 chars, for display (e.g. "sk_live_a1b2")
  last4      String              // last 4 chars, for display
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}


